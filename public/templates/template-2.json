{
  "id": "template-2",
  "name": "Modern Black & White",
  "layout": [
    { "type": "rect", "x": 0, "y": 0, "width": 220, "height": 842, "fill": "#000000" },
    { "type": "rect", "x": 220, "y": 0, "width": 375, "height": 842, "fill": "#e5e5e5" },
    { "type": "circle", "x": 110, "y": 100, "radius": 60, "fill": "#333" },

    { "field": "basics.name", "x": 20, "y": 180, "width": 180, "fontSize": 22, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#ffffff", "align": "center", "type": "dynamic" },
    { "field": "basics.title", "x": 20, "y": 210, "width": 180, "fontSize": 12, "fontFamily": "Arial", "fill": "#cccccc", "align": "center", "type": "dynamic" },

    { "type": "rect", "x": 20, "y": 250, "width": 180, "height": 30, "fill": "#ffffff", "cornerRadius": 15 },
    { "content": "CONTACT", "x": 20, "y": 258, "width": 180, "fontSize": 12, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#000000", "align": "center", "type": "static" },
    
    { "field": "basics.phone", "x": 20, "y": 300, "width": 180, "fontSize": 10, "fontFamily": "Arial", "fill": "#ffffff", "align": "center", "type": "dynamic" },
    { "field": "basics.email", "x": 20, "y": 315, "width": 180, "fontSize": 10, "fontFamily": "Arial", "fill": "#ffffff", "align": "center", "type": "dynamic" },
    { "field": "basics.location.city", "x": 20, "y": 330, "width": 180, "fontSize": 10, "fontFamily": "Arial", "fill": "#ffffff", "align": "center", "type": "dynamic" },

    { "type": "rect", "x": 20, "y": 380, "width": 180, "height": 30, "fill": "#ffffff", "cornerRadius": 15 },
    { "content": "SKILLS", "x": 20, "y": 388, "width": 180, "fontSize": 12, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#000000", "align": "center", "type": "static" },
    { "field": "skills", "x": 20, "y": 430, "width": 180, "fontSize": 10, "fontFamily": "Arial", "fill": "#ffffff", "align": "center", "type": "list", "format": "• {name}" },

    { "type": "rect", "x": 20, "y": 600, "width": 180, "height": 30, "fill": "#ffffff", "cornerRadius": 15 },
    { "content": "EDUCATION", "x": 20, "y": 608, "width": 180, "fontSize": 12, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#000000", "align": "center", "type": "static" },
    { "field": "education", "x": 20, "y": 650, "width": 180, "fontSize": 10, "fontFamily": "Arial", "fill": "#ffffff", "align": "center", "type": "list", "format": "{institution}\n{area}\n{startDate}-{endDate}" },

    { "content": "PROFILE", "x": 250, "y": 60, "fontSize": 14, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#000000", "type": "static" },
    { "type": "line", "points": [250, 80, 550, 80], "stroke": "#000", "strokeWidth": 1 },
    { "field": "basics.summary", "x": 250, "y": 100, "width": 300, "fontSize": 10, "fontFamily": "Arial", "fill": "#333", "type": "dynamic" },

    { "content": "WORK EXPERIENCE", "x": 250, "y": 200, "fontSize": 14, "fontFamily": "Arial", "fontStyle": "bold", "fill": "#000000", "type": "static" },
    { "type": "line", "points": [250, 220, 550, 220], "stroke": "#000", "strokeWidth": 1 },
    { "field": "work", "x": 250, "y": 240, "width": 300, "fontSize": 10, "fontFamily": "Arial", "fill": "#333", "type": "list", "format": "■ {position}\n{company} / {startDate} - {endDate}\n\n{summary}" }
  ]
}
